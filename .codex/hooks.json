{
  "hooks": {
    "session_start": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/run-hook.cmd session-start",
            "commandWindows": ".codex\\hooks\\run-hook.cmd session-start",
            "async": false,
            "timeout": 30,
            "statusMessage": "Loading Codex session context"
          }
        ]
      }
    ]
  }
}
