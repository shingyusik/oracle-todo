#!/usr/bin/env bash

set -euo pipefail

karpathy_skill_path="${HOME}/.claude/plugins/marketplaces/karpathy-skills/skills/karpathy-guidelines/SKILL.md"
superpowers_skill_path="${HOME}/.codex/skills/using-superpowers/SKILL.md"

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

context="<EXTREMELY_IMPORTANT>"

if [ -f "$karpathy_skill_path" ]; then
  karpathy_content="$(cat "$karpathy_skill_path")"
  context="${context}\nBelow is the full content of your karpathy-guidelines skill. Apply these guidelines to all code work this session. The guidelines are injected every session by this hook, so the Activation Workflow section is already satisfied - never ask its installation question.\n\n$(escape_for_json "$karpathy_content")\n"
fi

if [ -f "$superpowers_skill_path" ]; then
  superpowers_content="$(cat "$superpowers_skill_path")"
  context="${context}\nYou have superpowers.\n\nBelow is the full content of your using-superpowers skill. Apply it this session. The skill is injected every session by this hook, so its session-start activation requirement is already satisfied.\n\n$(escape_for_json "$superpowers_content")\n"
fi

context="${context}</EXTREMELY_IMPORTANT>"

if [ "$context" = "<EXTREMELY_IMPORTANT></EXTREMELY_IMPORTANT>" ]; then
  exit 0
fi

printf '{\n  "additional_context": "%s",\n  "additionalContext": "%s"\n}\n' "$context" "$context"

exit 0
